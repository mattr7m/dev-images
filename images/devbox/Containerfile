# devbox — kubeopencode-oriented base image for Agent pods
# Built from repo root:  podman build -t devbox -f images/devbox/Containerfile .
#
# Follows the kubeopencode agents/devbox/Dockerfile contract:
#   - pinned-date Debian slim base
#   - retry loops on every network touch
#   - arbitrary-UID / OpenShift contract (USER 1000:0, HOME=/tmp, XDG under /tmp)
#   - per-tool ARG pins; no inline versions in RUN
#   - layer ordering by concern: retry-helper → core utils → CLI tooling → workspace+user
FROM debian:bookworm-20260518-slim

LABEL org.opencontainers.image.source="https://github.com/mattr7m/dev-images"

# === Retry helper (layer 1 — retry helper) ===
ENV RETRY_COUNT=3
ENV RETRY_DELAY=5
SHELL ["/bin/bash", "-c"]

# === Core utilities (layer 2 — core utils) ===
# git, curl, jq, python3, tmux — the minimal shared set for all devbox derivatives
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    git \
    jq \
    python3 \
    python3-pip \
    tmux \
    wget \
    gnupg \
    && rm -rf /var/lib/apt/lists/*

# === CLI tooling (layer 3 — CLI tooling) ===

# GitHub CLI (gh) — latest from the gh apt repo, retry loop for apt source setup.
# (The previous GH_VERSION=2.93.0 pin was not available in the apt repo, so gh
# silently failed to install. Pin a repo-available version here if a specific
# gh is required.) Verify after the loop so an exhausted retry fails the build.
RUN for i in $(seq 1 $RETRY_COUNT); do \
      mkdir -p /etc/apt/keyrings \
      && curl -fsSL "https://cli.github.com/packages/githubcli-archive-keyring.gpg" \
         -o /etc/apt/keyrings/githubcli-archive-keyring.gpg \
      && chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg \
      && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
         > /etc/apt/sources.list.d/github-cli.list \
      && apt-get update && apt-get install -y --no-install-recommends gh \
      && rm -rf /var/lib/apt/lists/* \
      && break || { echo "gh retry $i/$RETRY_COUNT, waiting ${RETRY_DELAY}s..."; sleep $RETRY_DELAY; }; \
    done; \
    gh --version

# yq — pinned version, retry loop
ARG YQ_VERSION="v4.53.3"
RUN for i in $(seq 1 $RETRY_COUNT); do \
      curl -fsSL "https://github.com/mikefarah/yq/releases/download/${YQ_VERSION}/yq_linux_$(dpkg --print-architecture)" \
        -o /usr/local/bin/yq \
      && chmod +x /usr/local/bin/yq \
      && break || { echo "yq retry $i/$RETRY_COUNT, waiting ${RETRY_DELAY}s..."; sleep $RETRY_DELAY; }; \
    done; \
    yq --version

# kubectl — latest stable, retry loop. kubectl's download path uses the Debian
# arch names (amd64/arm64) directly — do NOT convert to x86_64/aarch64 (that 404s).
# Verify after the loop so an exhausted retry fails the build.
RUN for i in $(seq 1 $RETRY_COUNT); do \
      ARCH=$(dpkg --print-architecture) \
      && curl -fsSL "https://dl.k8s.io/release/$(curl -L -sf https://dl.k8s.io/release/stable.txt)/bin/linux/${ARCH}/kubectl" \
        -o /usr/local/bin/kubectl \
      && chmod +x /usr/local/bin/kubectl \
      && break || { echo "kubectl retry $i/$RETRY_COUNT, waiting ${RETRY_DELAY}s..."; sleep $RETRY_DELAY; }; \
    done; \
    kubectl version --client

# === Workspace setup (layer 4 — workspace+user) ===
ARG WORKSPACE_DIR=/workspace
ENV WORKSPACE_DIR=${WORKSPACE_DIR}

# Create workspace directory
RUN mkdir -p ${WORKSPACE_DIR} && chmod 777 ${WORKSPACE_DIR}

# === Environment variables (arbitrary-UID / OpenShift contract) ===
# Use /tmp as HOME so any arbitrary UID can write config/state
ENV HOME="/tmp"
ENV XDG_CONFIG_HOME="/tmp/.config"
ENV XDG_CACHE_HOME="/tmp/.cache"
ENV XDG_DATA_HOME="/tmp/.local/share"

# Pre-create directories with permissive ownership for arbitrary UIDs
RUN mkdir -p /tmp/.config /tmp/.cache /tmp/.local/share \
    && chmod -R 777 /tmp/.config /tmp/.cache /tmp/.local

# Switch to non-root (arbitrary-UID contract)
USER 1000:0

WORKDIR ${WORKSPACE_DIR}

# Default shell
CMD ["/bin/bash"]

